// This configuration is merged with the default vicinae configuration file, which you can obtain by running the `vicinae config default` command.
// Every item defined in this file takes precedence over the values defined in the default config or any other imported file.
//
// You can make manual edits to this file, however you should keep in mind that this file may be written to by vicinae when a configuration change is made through the GUI.
// When that happens, any custom comments or formatting will be lost.
//
// If you want to maintain a configuration file with your own comments and formatting, you should create a separate file and add it to the 'imports' array.
//
// Learn more about configuration at https://docs.vicinae.com/config

{
   "$schema": "https://vicinae.com/schemas/config.json",
   "activate_on_single_click": true,
   "font": {
      "normal": {
         "family": "Maple Mono Normal NFPropo"
      }
   },
   "theme": {
      "dark": {
         "name": "matugen"
      },
      "light": {
         "name": "matugen"
      }
   },
   "telemetry": {
      "system_info": false
   },
   "launcher_window": {
      "opacity": 0.98
   },
   "providers": {
      "@sovereign/store.vicinae.awww-switcher": {
         "preferences": {
            "wallpaperPath": "Pictures/Wallpaper",
            "colorGenTool": "none",
            "gridRows": "6",
            "postProduction": "no",
            "showImageDetails": true,
            "toggleVicinaeSetting": true,
            "transitionDuration": "3",
            "transitionFPS": "60",
            "transitionStep": "90",
            "transitionType": "wave",
            "postCommand": "wallswitch.sh ${wallpaper}"
         }
      },
      "applications": {
         "entrypoints": {
            "assistant": {
               "enabled": false
            },
            "avahi-discover": {
               "enabled": false
            },
            "bssh": {
               "enabled": false
            },
            "bvnc": {
               "enabled": false
            },
            "cmake-gui": {
               "enabled": false
            },
            "designer": {
               "enabled": false
            },
            "linguist": {
               "enabled": false
            },
            "micro": {
               "enabled": false
            },
            "nm-connection-editor": {
               "enabled": false
            },
            "octopi-cachecleaner": {
               "enabled": false
            },
            "octopi-notifier": {
               "enabled": false
            },
            "octopi-repoeditor": {
               "enabled": false
            },
            "org.gnome.Nautilus": {
               "enabled": false
            },
            "org.kde.ark": {
               "enabled": false
            },
            "qdbusviewer": {
               "enabled": false
            },
            "qt6ct": {
               "enabled": false
            },
            "qv4l2": {
               "enabled": false
            },
            "qvidcap": {
               "enabled": false
            },
            "rofi": {
               "enabled": false
            },
            "rofi-theme-selector": {
               "enabled": false
            },
            "vim": {
               "enabled": false
            },
            "xgps": {
               "enabled": false
            },
            "xgpsspeed": {
               "enabled": false
            }
         }
      }
   }
}
