{
   "$schema": "https://vicinae.com/schemas/config.json",
   "activate_on_single_click": true,
   "font": {
      "normal": {
         "family": "Maple Mono Normal NFPropo"
      }
   },
   "theme": {
      "dark": {
         "name": "matugen"
      },
      "light": {
         "name": "matugen"
      }
   },
   "telemetry": {
      "system_info": false
   },
   "launcher_window": {
      "opacity": 0.98
   },
   "providers": {
      "@sovereign/store.vicinae.awww-switcher": {
         "preferences": {
            "wallpaperPath": "Pictures/Wallpaper",
            "colorGenTool": "none",
            "gridRows": "6",
            "postProduction": "no",
            "showImageDetails": true,
            "toggleVicinaeSetting": true,
            "transitionDuration": "3",
            "transitionFPS": "60",
            "transitionStep": "90",
            "transitionType": "wave",
            "postCommand": "wallswitch.sh ${wallpaper}"
         }
      },
      "applications": {
         "entrypoints": {
            "assistant": {
               "enabled": false
            },
            "avahi-discover": {
               "enabled": false
            },
            "bssh": {
               "enabled": false
            },
            "bvnc": {
               "enabled": false
            },
            "cmake-gui": {
               "enabled": false
            },
            "designer": {
               "enabled": false
            },
            "linguist": {
               "enabled": false
            },
            "micro": {
               "enabled": false
            },
            "nm-connection-editor": {
               "enabled": false
            },
            "octopi-cachecleaner": {
               "enabled": false
            },
            "octopi-notifier": {
               "enabled": false
            },
            "octopi-repoeditor": {
               "enabled": false
            },
            "org.gnome.Nautilus": {
               "enabled": false
            },
            "org.kde.ark": {
               "enabled": false
            },
            "qdbusviewer": {
               "enabled": false
            },
            "qt6ct": {
               "enabled": false
            },
            "qv4l2": {
               "enabled": false
            },
            "qvidcap": {
               "enabled": false
            },
            "rofi": {
               "enabled": false
            },
            "rofi-theme-selector": {
               "enabled": false
            },
            "vim": {
               "enabled": false
            },
            "xgps": {
               "enabled": false
            },
            "xgpsspeed": {
               "enabled": false
            }
         }
      }
      "core": {
         "entrypoints": {
            "about": {
               "enabled": false
            },
            "documentation": {
               "enabled": false
            },
            "inspect-local-storage": {
               "enabled": false
            },
            "open-default-config": {
               "enabled": false
            },
            "report-bug": {
               "enabled": false
            },
            "sponsor": {
               "enabled": false
            },
            "store": {
               "preferences": {
                  "alwaysShowIntro": false
               }
            }
         }
      },
      "developer": {
         "enabled": false
      },
      "files": {
         "enabled": false,
         "preferences": {
            "autoIndexing": false,
            "excludedPaths": ".cache"
         }
      },
      "power": {
         "entrypoints": {
            "sleep": {
               "preferences": {
                  "confirm": false
               }
            },
            "suspend": {
               "preferences": {
                  "confirm": false
               }
            }
         }
      },
      "system": {
         "entrypoints": {
            "run": {
               "preferences": {
                  "default-action": "run-in-terminal-hold"
               }
            }
         }
      }
   }
}
